//   This formula has NO relationship to Rwanda's district boundaries.
//   A click anywhere on the map returned a mathematically random district
//   name and data that bore no connection to the clicked location.
//
// THE FIX:
//   1. Build a point geometry from the click coordinates.
//   2. Use districtFC.filterBounds(point) to find the district polygon
//      that contains the clicked point. districtFC has REAL geometries
//      from FAO GAUL level-2 AND the gender attributes joined in Section 1.
//   3. Call .first().evaluate() to bring the matched feature's properties
//      to the client side, then pass them to updateInspectPanel().
//   This guarantees the panel always shows data for the district that was
//   actually clicked, not a random index.

// ── VISUAL HELPER: colour-coded progress bar ──────────────────────────────────
// pct    : 0–100 fill percentage
// barColor : hex colour of the filled portion
// Returns a horizontal panel containing the filled + empty bar segments
function progressBar(pct, barColor) {
  var filled = Math.max(1, Math.round(pct));
  var empty  = 100 - filled;
  var barW   = 250; // total bar width in px
  var filledW = Math.round(barW * filled / 100);
  var emptyW  = barW - filledW;
  return ui.Panel({
    layout: ui.Panel.Layout.flow('horizontal'),
    style: { backgroundColor:'#0D1B12', margin:'4px 0px 2px 0px', padding:'0px' },
    widgets: [
      ui.Label('', {
        backgroundColor: barColor,
        width: filledW + 'px', height: '7px',
        margin: '0px', padding: '0px',
        borderRadius: '3px'
      }),
      ui.Label('', {
        backgroundColor: '#2A4A36',
        width: emptyW + 'px', height: '7px',
        margin: '0px', padding: '0px',
        borderRadius: '3px'
      })
    ]
  });
}

// ── VISUAL HELPER: single indicator card ────────────────────────────────────
// Each card shows: icon + label on top row, large coloured value + severity
// dot on middle row, and a progress bar on the bottom row.
//
// Parameters:
//   icon       : emoji string
//   label      : indicator name
//   rawValue   : the number to display (with units appended)
//   unit       : unit string appended to value
//   pct        : 0-100 fill for progress bar (normalised to range)
//   valColor   : hex colour of the value text and bar fill
//   severity   : 'GOOD' | 'WARN' | 'RISK'  → dot colour
function indicatorCard(icon, label, rawValue, unit, pct, valColor, severity) {
  var dotColor = severity === 'GOOD' ? '#66BB6A'
               : severity === 'WARN' ? '#FFB74D' : '#EF5350';
  var severityText = severity === 'GOOD' ? 'Good'
                   : severity === 'WARN' ? 'Moderate' : 'High risk';

  var card = ui.Panel({
    layout: ui.Panel.Layout.flow('vertical'),
    style: {
      backgroundColor: '#162A1E',
      border: '1px solid ' + CFG.clrBorder,
      borderRadius: '6px',
      padding: '8px 10px',
      margin: '0px 0px 6px 0px'
    }
  });

  // Row 1: icon + label
  card.add(ui.Panel({
    layout: ui.Panel.Layout.flow('horizontal'),
    style: { backgroundColor: '#162A1E', margin: '0px 0px 4px 0px', padding: '0px' },
    widgets: [
      ui.Label(icon, { fontSize: '13px', margin: '0px 6px 0px 0px' }),
      ui.Label(label, {
        color: CFG.clrTextMuted, fontSize: '10px',
        fontWeight: '600', margin: '0px', stretch: 'horizontal'
      })
    ]
  }));

  // Row 2: large value + severity dot
  card.add(ui.Panel({
    layout: ui.Panel.Layout.flow('horizontal'),
    style: { backgroundColor: '#162A1E', margin: '0px 0px 4px 0px', padding: '0px' },
    widgets: [
      ui.Label(String(rawValue) + ' ' + unit, {
        color: valColor, fontSize: '16px', fontWeight: '900',
        margin: '0px', stretch: 'horizontal'
      }),
      ui.Label('● ' + severityText, {
        color: dotColor, fontSize: '10px', fontWeight: '700', margin: '0px'
      })
    ]
  }));

  // Row 3: progress bar
  card.add(progressBar(pct, valColor));

  return card;
}

