// SECTION 2 ── SATELLITE IMAGERY LAYERS
// ══════════════════════════════════════════════════════════════════════════════

var s2 = ee.ImageCollection('COPERNICUS/S2_SR_HARMONIZED')
  .filterBounds(rwandaBounds)
  .filterDate('2023-01-01', '2023-12-31')
  .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE', 15))
  .select(['B4','B3','B2'])
  .median()
  .clip(rwandaBounds);

var l8 = ee.ImageCollection('LANDSAT/LC08/C02/T1_L2')
  .filterBounds(rwandaBounds)
  .filterDate('2023-01-01', '2023-12-31')
  .filter(ee.Filter.lt('CLOUD_COVER', 20))
  .map(function(img) {
    var nir = img.select('SR_B5').multiply(0.0000275).add(-0.2);
    var red = img.select('SR_B4').multiply(0.0000275).add(-0.2);
    return img.addBands(nir.subtract(red).divide(nir.add(red)).rename('NDVI'));
  })
  .select('NDVI')
  .median()
  .clip(rwandaBounds);

var dem   = ee.Image('USGS/SRTMGL1_003').clip(rwandaBounds);
var slope = ee.Terrain.slope(dem);

var ntl = ee.ImageCollection('NOAA/VIIRS/DNB/MONTHLY_V1/VCMCFG')
