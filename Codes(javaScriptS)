// ── THE FIXED CLICK HANDLER ───────────────────────────────────────────────────
map.onClick(function(coords) {
  var lon = coords.lon;
  var lat = coords.lat;

  // Show loading feedback immediately
  loadingLabel.setValue('⏳ Identifying district...');
  inspectPanel.clear();
  chartPanel.clear();
  if (STATE.activeTab !== 'explore') switchTab('explore');

  // Remove previous click marker
  map.layers().forEach(function(layer) {
    if (layer.getName && layer.getName() === '__click_marker__') {
      map.remove(layer);
    }
  });

  // Place gold dot at click point
  var pt = ee.Geometry.Point([lon, lat]);
  map.addLayer(
    ee.FeatureCollection([ee.Feature(pt)]).style({ color:'#FFD600', pointSize:8, pointShape:'circle' }),
    {}, '__click_marker__'
  );

  // ── SPATIAL JOIN: find which district polygon contains the click ──────────
  // filterBounds returns all features whose geometry intersects the point.
  // .first() selects the one matching district polygon.
  // .evaluate() sends the feature's properties to the client side
  // asynchronously (GEE is server-side; evaluate() bridges to client JS).
  var clickedDistrict = districtFC.filterBounds(pt).first();

  clickedDistrict.evaluate(function(feature, error) {
    if (error) {
      // Handle cases where click lands outside Rwanda boundaries
      loadingLabel.setValue('⚠️ Click landed outside Rwanda district boundaries. Try again.');
      return;
    }
    if (!feature || !feature.properties) {
      loadingLabel.setValue('⚠️ No district found at this location. Click inside Rwanda.');
      return;
    }

    var props = feature.properties;

    // If the join produced the GAUL name but not district (edge case),
    // fall back to the ADM2_NAME from GAUL.
    if (!props.district) {
      props.district = props.ADM2_NAME || 'Unknown District';
    }
    if (!props.province) {
      props.province = props.ADM1_NAME || 'Rwanda';
    }

    STATE.selectedDistrict = props.district;
    updateInspectPanel(props);
  });
});


