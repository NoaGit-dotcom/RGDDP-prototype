// SECTION 3 ── CHOROPLETH IMAGES  (painted from spatially joined districtFC)
// ══════════════════════════════════════════════════════════════════════════════
//
// FIX: We now paint from districtFC (which has real geometries) instead of
// the geometry-less genderFC. This ensures the choropleth colours align with
// the actual district polygons visible on the map.

function paintIndicator(fc, property) {
  return ee.Image().float().paint(fc, property);
}

