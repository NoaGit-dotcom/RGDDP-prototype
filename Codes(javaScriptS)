// ── clearInspector() — wired to the Clear button ─────────────────────────────
// Resets every element the click handler populates:
//   1. Removes the gold click marker from the map
//   2. Clears the loading status label
//   3. Restores the "No district selected" placeholder in inspectPanel
//   4. Clears the trend chart panel
//   5. Resets STATE.selectedDistrict to null
function clearInspector() {
  // 1. Remove gold click marker from map layers
  map.layers().forEach(function(layer) {
    if (layer.getName && layer.getName() === '__click_marker__') {
      map.remove(layer);
    }
  });

  // 2. Clear the loading / error label
  loadingLabel.setValue('');

  // 3. Reset inspect panel to placeholder
  inspectPanel.clear();
  inspectPanel.add(inspectPlaceholder);

  // 4. Clear trend chart
  chartPanel.clear();

  // 5. Reset selected district in app state
  STATE.selectedDistrict = null;
}


