function updateLayerInfo() {
  var layer = LAYERS[STATE.activeLayer];
  if (!layer) return;
  layerInfoTitle.setValue(layer.icon + '  ' + layer.label);
  layerInfoUnit.setValue('Unit: ' + layer.unit);
  layerInfoDesc.setValue(layer.desc);
}

function updateMapLayer() {
  var key   = STATE.activeLayer;
  var layer = LAYERS[key];
  if (!layer) return;
  if (STATE.layerHandles.gender) map.remove(STATE.layerHandles.gender);
  var mapLayer = ui.Map.Layer(layer.image, layer.vis, layer.label, true, 0.85);
  map.layers().add(mapLayer, 0);
  STATE.layerHandles.gender = mapLayer;
  if (STATE.layerHandles.outline) map.remove(STATE.layerHandles.outline);
  var outline = ui.Map.Layer(districtOutline, { palette:['#4CAF7D'] }, 'District Boundaries', true, 0.6);
  map.layers().add(outline);
  STATE.layerHandles.outline = outline;
  updateLegend(key, layer);
}

function updateSatelliteLayer(key) {
  if (STATE.layerHandles.satellite) { map.remove(STATE.layerHandles.satellite); STATE.layerHandles.satellite = null; }
  if (key === 'none') return;
  var layer = LAYERS[key];
  if (!layer) return;
  var satLayer = ui.Map.Layer(layer.image, layer.vis, layer.label + ' (satellite)', true, 0.75);
  map.layers().insert(0, satLayer);
  STATE.layerHandles.satellite = satLayer;
}


