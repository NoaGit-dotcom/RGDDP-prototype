// SECTION 1 ── DISTRICT DATA  (spatially joined to real boundaries)
// ══════════════════════════════════════════════════════════════════════════════
//
// FIX: Gender attributes are now joined to the actual FAO GAUL level-2
// district polygons using the district NAME as the join key.
// Every Feature in districtFC has both geometry AND gender properties,
// so filterBounds(clickedPoint) returns the correct district every time.
//
// In production replace syntheticValue() calls with real asset values:
//   var realData = ee.FeatureCollection('users/YOUR_USERNAME/rwanda_districts');
//   var districtFC = realData;  // must contain geometry + all properties below

// ── 1a. Load Rwanda admin-2 boundaries (districts) from FAO GAUL ─────────────
// FAO GAUL level-2 for Rwanda gives the 30 individual district polygons.
var rwandaDistricts = ee.FeatureCollection('FAO/GAUL/2015/level2')
  .filter(ee.Filter.eq('ADM0_NAME', 'Rwanda'));

// Also keep the country outline for boundary drawing
var rwandaBounds = ee.FeatureCollection('FAO/GAUL/2015/level1')
  .filter(ee.Filter.eq('ADM0_NAME', 'Rwanda'));

// ── 1b. Gender attribute lookup (keyed by district name) ─────────────────────
// The GAUL level-2 ADM2_NAME field stores district names. We build a lookup
// that maps each name to its synthetic gender data, then join it to the
// polygon FeatureCollection so every polygon carries its own attributes.

// Deterministic synthetic value generator (same as original)
function syntheticValue(idx, min, max, seed) {
  var x = Math.sin(idx * 9.301 + seed * 2.718) * 43758.5453;
  x = x - Math.floor(x);
  return Math.round((min + x * (max - min)) * 10) / 10;
}

// Rwanda's 30 district names in alphabetical order — matches GAUL ADM2_NAME
// exactly. Index position is used for syntheticValue() so data is consistent.
var DISTRICT_NAMES = [
  'Bugesera','Burera','Gakenke','Gasabo','Gatsibo','Gicumbi','Gisagara',
  'Huye','Kamonyi','Karongi','Kayonza','Kicukiro','Kirehe','Muhanga',
  'Musanze','Ngoma','Ngororero','Nyabihu','Nyagatare','Nyamagabe',
  'Nyamasheke','Nyanza','Nyarugenge','Nyaruguru','Rubavu','Ruhango',
  'Rulindo','Rusizi','Rutsiro','Rwamagana'
];

var PROVINCES = [
  'Eastern','Northern','Northern','Kigali','Eastern','Northern',
  'Southern','Southern','Southern','Western','Eastern','Kigali','Eastern',
  'Southern','Northern','Eastern','Western','Western','Eastern','Southern',
  'Western','Southern','Kigali','Southern','Western','Southern','Northern',
  'Western','Western','Eastern'
];

// Build a list of ee.Feature objects (no geometry) holding gender attributes,
// one per district, with district name as the join field.
var genderFeatures = DISTRICT_NAMES.map(function(name, i) {
  var gbv         = syntheticValue(i,  80,  420, 1);
  var girlsEnrol  = syntheticValue(i,  42,   94, 2);
  var femLand     = syntheticValue(i,  12,   51, 3);
  var matMort     = syntheticValue(i, 150,  560, 4);
  var femLeader   = syntheticValue(i,  38,   72, 5);
  var dataSources = Math.round(syntheticValue(i, 1, 8, 6));
  var ntlProxy    = syntheticValue(i, 0.02, 0.85, 7);

  var nGBV    = (gbv - 80)        / (420 - 80);
  var nEnrol  = 1 - (girlsEnrol - 42)  / (94 - 42);
  var nLand   = 1 - (femLand  - 12)    / (51 - 12);
  var nMat    = (matMort - 150)   / (560 - 150);
  var nLeader = 1 - (femLeader - 38)   / (72 - 38);
  var nNTL    = 1 - ntlProxy;
  var gvi = Math.round((
    nGBV    * 0.25 +
    nEnrol  * 0.20 +
    nLand   * 0.20 +
    nMat    * 0.20 +
    nLeader * 0.10 +
    nNTL    * 0.05
  ) * 100) / 100;

  var gap = dataSources <= 2 ? 'HIGH GAP' : dataSources <= 4 ? 'MODERATE' : 'COVERED';

  // The join key must match the GAUL ADM2_NAME exactly
  return ee.Feature(null, {
    join_name    : name,
    district     : name,
    province     : PROVINCES[i] || 'Rwanda',
    gbv_rate     : gbv,
    girls_enrol  : girlsEnrol,
    fem_land     : femLand,
    mat_mort     : matMort,
    fem_leader   : femLeader,
    data_sources : dataSources,
    ntl_proxy    : ntlProxy,
    gvi          : gvi,
    gap_status   : gap,
    institution  : 'NISR / MIGEPROF / UNFPA',
    last_updated : '2024-Q4',
    access_url   : 'https://www.statistics.gov.rw'
  });
});

var genderFC = ee.FeatureCollection(genderFeatures);

// ── 1c. Spatial join: attach gender attributes to district polygons ───────────
// saveFirst join: for each district polygon (left), find the matching gender
// feature (right) where ADM2_NAME == join_name, then copy all properties.
var districtJoin = ee.Join.saveFirst('gender_match');
var joinFilter   = ee.Filter.equals({
  leftField : 'ADM2_NAME',   // field in rwandaDistricts (GAUL)
  rightField: 'join_name'    // field in genderFC
});

var joinedRaw = districtJoin.apply(rwandaDistricts, genderFC, joinFilter);

// Flatten: copy the matched gender properties onto the polygon feature
var districtFC = joinedRaw.map(function(feat) {
  var match = ee.Feature(feat.get('gender_match'));
  return feat
    .set('district',     match.get('district'))
    .set('province',     match.get('province'))
    .set('gbv_rate',     match.get('gbv_rate'))
    .set('girls_enrol',  match.get('girls_enrol'))
    .set('fem_land',     match.get('fem_land'))
    .set('mat_mort',     match.get('mat_mort'))
    .set('fem_leader',   match.get('fem_leader'))
    .set('data_sources', match.get('data_sources'))
    .set('ntl_proxy',    match.get('ntl_proxy'))
    .set('gvi',          match.get('gvi'))
    .set('gap_status',   match.get('gap_status'))
    .set('institution',  match.get('institution'))
    .set('last_updated', match.get('last_updated'))
    .set('access_url',   match.get('access_url'));
});

// districtFC now has real geometries + gender attributes.
// filterBounds(point) on this collection returns the correct district polygon.


